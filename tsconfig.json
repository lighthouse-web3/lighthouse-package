{
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["es2016"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,  
    "target": "ES2015",
    "module": "commonjs",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}