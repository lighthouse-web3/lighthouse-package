{
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["es6"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,  
    "target": "ES2020",
    "module": "CommonJS",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "allowJs": true,
  },
  "include": ["src","src/**/*.ts", "Commands/*.ts","cli.ts","index.ts","node_modules/conf"],
  "exclude": ["node_modules", "**/*.spec.ts","**/*.test.ts",".vscode"]
}